<%layout("/layouts/boilerplate.ejs")%>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-2">
      <h3>Bookings for <%=listing.title%></h3>
      <p class="text-muted"><%=listing.location%>, <%=listing.country%></p>
      <hr>

      <% if(bookings.length === 0) { %>
        <p class="text-muted">No confirmed bookings yet for this listing.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-bordered">
            <thead class="table-dark">
              <tr>
                <th>Guest Name</th>
                <th>Email</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Guests</th>
                <th>Amount Paid</th>
              </tr>
            </thead>
            <tbody>
              <% for(let b of bookings) { %>
                <tr>
                  <td><%=b.guestName%></td>
                  <td><%=b.guestEmail%></td>
                  <td><%=b.checkIn.toDateString()%></td>
                  <td><%=b.checkOut.toDateString()%></td>
                  <td><%=b.guests%></td>
                  <td>&#8377;<%=b.totalAmount.toLocaleString("en-IN")%></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>

      <a href="/listings/<%=listing._id%>" class="btn btn-dark mt-3">Back to Listing</a>
      <br><br>
    </div>
  </div>
</body>
