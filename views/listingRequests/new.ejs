<%layout("/layouts/boilerplate.ejs")%>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-2">
      <h2>Submit Your Listing</h2>
      <p class="text-muted">Fill in the details below. Admin will review and approve your listing.</p>
      <hr>
      <br>
      <form action="/listing-requests" method="POST" novalidate class="needs-validation">

        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            name="listingRequest[title]"
            type="text"
            placeholder="Enter a catchy title"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please enter a title</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea
            name="listingRequest[description]"
            placeholder="Describe your property"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">Please enter a description</div>
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Image URL</label>
          <input
            name="listingRequest[image]"
            type="text"
            placeholder="Paste an image link"
            class="form-control"
          />
        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price per night (&#8377;)</label>
            <input
              name="listingRequest[price]"
              type="number"
              placeholder="1200"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Please enter a valid price</div>
          </div>

          <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input
              name="listingRequest[country]"
              type="text"
              placeholder="India"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Please enter a country</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input
            name="listingRequest[location]"
            type="text"
            placeholder="Jaipur, Rajasthan"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please enter a location</div>
        </div>

        <br>
        <button class="btn btn-dark add-btn" type="submit">Submit for Review</button>
        <a href="/listings" class="btn btn-outline-secondary ms-2">Cancel</a>
        <br><br>
      </form>
    </div>
  </div>
</body>
