<%layout("./layouts/boilerplate.ejs")%>
<body>
  
<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3> <%=listing.title%> </h3>
  </div>
    <div class="card col-6 offset-3 show-card listing-card">
      <img src="<%= listing.image && listing.image.url ? listing.image.url : listing.image %>" class="card-img-top show-img" alt="listing_image">

      <div class="card-body">
        <p class="card-text">
          
          <%=listing.description%> <br>
          &#8377;<%=listing.price.toLocaleString("en-IN")%> <br>
          <%=listing.location%> <br>
          <%=listing.country%> <br>
        </p>
      </div>
    </div>
</div>

<div class="btns">
  <% if(currUser && currUser.isAdmin) { %>
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>
    <form action="/listings/<%=listing._id%>?_method=DELETE" method="POST">
      <button class="btn btn-dark offset-5">Delete</button>
    </form>
  <% } %>
</div>

<div class="col-8 offset-3 mt-3">
  <% if(currUser && !currUser.isAdmin) { %>
    <a href="/listings/<%=listing._id%>/booking/new" class="btn btn-danger">
      <i class="fa-solid fa-calendar-check me-1"></i> Book Now
    </a>
    <a href="/listings/<%=listing._id%>/booking" class="btn btn-outline-dark ms-2">
      My Bookings for this Listing
    </a>
  <% } else if(currUser && currUser.isAdmin) { %>
    <a href="/listings/<%=listing._id%>/booking" class="btn btn-outline-dark">
      View All Bookings
    </a>
  <% } else { %>
    <a href="/login" class="btn btn-danger">
      <i class="fa-solid fa-calendar-check me-1"></i> Log in to Book
    </a>
  <% } %>
</div>
<br><br>

<div class="col-8 offset-3">
  <hr>
  <% if(currUser) { %>
    <h3>Leave a Review</h3>
    <form action="/listings/<%=listing._id%>/review" method="POST" novalidate class="needs-validation">
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <input type="range" id="rating" name="review[rating]" min="1" max="5" class="form-range"/>
      </div>

      <div class="mb-3 mt-3">
        <label for="comment" class="form-label"></label>
        <textarea
        id="comment"
        name="review[comment]"
        cols="30"
        rows="5"
        placeholder="Write a review"
        class="form-control"
        required
      ></textarea>
        <div class="invalid-feedback">
          Please add some comments for review
        </div>
      </div>

      <button type="submit" class="btn btn-outline-dark mb-3 mt-3">Submit</button>
    </form>
  <% } else { %>
    <p class="text-muted"><a href="/login">Log in</a> to leave a review.</p>
  <% } %>

  <hr>
  <p><b>All Reviews</b></p>
  <div class="row">
    <% for(review of listing.review){ %>
      <div class=" card card-body mb-3 col-4 ms-3">
        <h5 class="card-title">
          <i class="fa-regular fa-user me-1"></i>
          <%=review.author ? review.author.username : "Anonymous"%>
        </h5>
        <p class="card-text"><%=review.comment%></p>
        <p class="card-text"><%=review.rating%> stars</p>
        <% if(currUser && (currUser.isAdmin || (review.author && review.author._id.equals(currUser._id)))) { %>
          <form class="mb-3" method="POST" action="/listings/<%=listing._id%>/review/<%=review._id%>?_method=DELETE">
            <button class="btn btn-dark btn-sm">Delete</button>
          </form>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
</body>
