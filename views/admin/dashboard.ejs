<%layout("/layouts/boilerplate.ejs")%>
<body>
  <div class="row mt-3">
    <div class="col-10 offset-1">
      <h2><i class="fa-solid fa-shield-halved me-2"></i>Admin Dashboard</h2>
      <p class="text-muted">Welcome, <%=currUser.username%></p>
      <hr>

      <!-- stats row -->
      <div class="row text-center mb-4 mt-3">
        <div class="col-md-4 mb-3">
          <div class="card p-3">
            <h2 class="text-danger"><%=totalListings%></h2>
            <p class="text-muted mb-0">Total Listings</p>
          </div>
        </div>
        <div class="col-md-4 mb-3">
          <div class="card p-3">
            <h2 class="text-danger"><%=totalBookings%></h2>
            <p class="text-muted mb-0">Total Bookings</p>
          </div>
        </div>
        <div class="col-md-4 mb-3">
          <div class="card p-3">
            <h2 class="text-danger"><%=totalRequests%></h2>
            <p class="text-muted mb-0">Pending Requests</p>
          </div>
        </div>
      </div>

      <!-- quick links -->
      <div class="mb-4">
        <a href="/listings/new" class="btn btn-dark me-2">Add Listing Directly</a>
        <a href="/admin/requests" class="btn btn-outline-dark me-2">All Requests</a>
        <a href="/admin/bookings" class="btn btn-outline-dark">All Bookings</a>
      </div>

      <hr>
      <h4>Pending Listing Requests</h4>

      <% if(pendingRequests.length === 0) { %>
        <p class="text-muted mt-3">No pending requests right now.</p>
      <% } else { %>
        <% for(let r of pendingRequests) { %>
          <div class="card mb-3 p-3">
            <div class="row">
              <div class="col-md-8">
                <h5><%=r.title%></h5>
                <p class="mb-1 text-muted"><%=r.location%>, <%=r.country%></p>
                <p class="mb-1"><%=r.description%></p>
                <p class="mb-1"><b>Price:</b> &#8377;<%=r.price.toLocaleString("en-IN")%>/night</p>
                <p class="mb-1 text-muted">
                  Submitted by: <b><%=r.submittedBy.username%></b> on <%=r.createdAt.toDateString()%>
                </p>
              </div>
              <div class="col-md-4 d-flex align-items-center justify-content-end gap-2">
                <form action="/admin/requests/<%=r._id%>/approve" method="POST">
                  <button class="btn btn-success">Approve</button>
                </form>
                <form action="/admin/requests/<%=r._id%>/reject" method="POST">
                  <button class="btn btn-danger">Reject</button>
                </form>
              </div>
            </div>
          </div>
        <% } %>
      <% } %>
      <br>
    </div>
  </div>
</body>
