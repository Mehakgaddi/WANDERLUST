<%layout("/layouts/boilerplate.ejs")%>
<body>
  <div class="row mt-3">
    <div class="col-10 offset-1">
      <h2>All Bookings</h2>
      <a href="/admin/dashboard" class="text-muted">← Back to Dashboard</a>
      <hr>

      <% if(allBookings.length === 0) { %>
        <p class="text-muted mt-3">No confirmed bookings yet.</p>
      <% } else { %>
        <div class="table-responsive mt-3">
          <table class="table table-bordered">
            <thead class="table-dark">
              <tr>
                <th>Listing</th>
                <th>Guest Name</th>
                <th>Email</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Guests</th>
                <th>Amount</th>
                <th>Payment ID</th>
              </tr>
            </thead>
            <tbody>
              <% for(let b of allBookings) { %>
                <tr>
                  <td><%=b.listing ? b.listing.title : "Deleted Listing"%></td>
                  <td><%=b.guestName%></td>
                  <td><%=b.guestEmail%></td>
                  <td><%=b.checkIn.toDateString()%></td>
                  <td><%=b.checkOut.toDateString()%></td>
                  <td><%=b.guests%></td>
                  <td>&#8377;<%=b.totalAmount.toLocaleString("en-IN")%></td>
                  <td><small class="text-muted"><%=b.paymentId%></small></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>
      <br>
    </div>
  </div>
</body>
